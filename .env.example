# Example environment variables for PDI Risk Dashboard
# Copy this to .env and fill in your values
# Then load in app.py with: from dotenv import load_dotenv; load_dotenv()

# Streamlit configuration
STREAMLIT_SERVER_PORT=8503
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true

# Data paths (if using remote data sources)
# DATA_API_URL=https://api.example.com/data
# DATA_API_KEY=your_key_here

# Database connections (if needed)
# DATABASE_URL=postgresql://user:password@localhost/dbname
